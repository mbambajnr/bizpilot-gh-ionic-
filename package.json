{
  "name": "bizpilot-gh-ionic",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Mobile-first Ghana SME operations demo built with Ionic React.",
  "scripts": {
    "dev": "concurrently -n EMAIL,WEB -c cyan,green \"npm run dev:email\" \"npm run dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:email": "node --env-file=.env.server server/index.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "remotion:studio": "remotion studio remotion/index.ts",
    "remotion:render:overview:vertical": "remotion render remotion/index.ts BisaPilotOverview15Vertical out/bisapilot-overview-15-vertical.mp4",
    "remotion:render:overview:square": "remotion render remotion/index.ts BisaPilotOverview15Square out/bisapilot-overview-15-square.mp4",
    "remotion:render:overview:landscape": "remotion render remotion/index.ts BisaPilotOverview15Landscape out/bisapilot-overview-15-landscape.mp4",
    "remotion:render:premium:vertical": "remotion render remotion/index.ts BisaPilotPremium15Vertical out/bisapilot-premium-15-vertical.mp4",
    "remotion:render:premium:square": "remotion render remotion/index.ts BisaPilotPremium15Square out/bisapilot-premium-15-square.mp4",
    "remotion:render:premium:landscape": "remotion render remotion/index.ts BisaPilotPremium15Landscape out/bisapilot-premium-15-landscape.mp4",
    "remotion:render:manifesto:vertical": "remotion render remotion/index.ts BisaPilotManifesto15Vertical out/bisapilot-manifesto-15-vertical.mp4",
    "remotion:render:manifesto:square": "remotion render remotion/index.ts BisaPilotManifesto15Square out/bisapilot-manifesto-15-square.mp4",
    "remotion:render:manifesto:landscape": "remotion render remotion/index.ts BisaPilotManifesto15Landscape out/bisapilot-manifesto-15-landscape.mp4",
    "remotion:render:comingsoon:vertical": "remotion render remotion/index.ts BisaPilotComingSoon15Vertical out/bisapilot-coming-soon-15-vertical.mp4",
    "remotion:render:comingsoon:square": "remotion render remotion/index.ts BisaPilotComingSoon15Square out/bisapilot-coming-soon-15-square.mp4",
    "remotion:render:comingsoon:landscape": "remotion render remotion/index.ts BisaPilotComingSoon15Landscape out/bisapilot-coming-soon-15-landscape.mp4",
    "test.e2e": "start-server-and-test 'npm run dev' http://127.0.0.1:5173 'npm run cypress:run'",
    "test.unit": "vitest",
    "lint": "eslint",
    "cypress:run": "cypress run",
    "cypress:open": "cypress open"
  },
  "dependencies": {
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@ionic/react": "^8.5.0",
    "@ionic/react-router": "^8.5.0",
    "@remotion/cli": "^4.0.448",
    "@supabase/supabase-js": "^2.103.2",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "concurrently": "^9.2.1",
    "ionicons": "^7.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "nodemailer": "^8.0.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4",
    "remotion": "^4.0.448"
  },
  "devDependencies": {
    "@testing-library/dom": ">=7.21.4",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-legacy": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.1",
    "concurrently": "^9.2.1",
    "cypress": "^13.5.0",
    "eslint": "^9.20.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^22.1.0",
    "start-server-and-test": "^3.0.2",
    "terser": "^5.4.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^5.0.0",
    "vitest": "^0.34.6"
  },
  "author": "mbambajnr",
  "license": "UNLICENSED"
}
